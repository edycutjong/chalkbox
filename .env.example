# ============================================================
# Chalkbox — environment
# ------------------------------------------------------------
# The app runs FULLY in DEMO MODE with NONE of these set: the
# seeded gallery + the stubbed self-test build timeline work
# with zero keys. Fill these only to wire the real Codex +
# Supabase engine behind the seams marked `// STUB:`.
# ============================================================

# --- Demo toggle -------------------------------------------
# "true" forces demo mode; "false" enables real mode (needs OPENAI_API_KEY).
# Left unset, the app is in demo mode unless OPENAI_API_KEY is present.
CHALKBOX_DEMO_MODE=true

# --- OpenAI / Codex ----------------------------------------
# GPT-5.6 Sol (generation) + Luna (safety/triage) via the Codex SDK.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Supabase (share links + gallery persistence) ----------
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
