# ============================================================
# Chalkbox — environment
# ------------------------------------------------------------
# The app runs FULLY in DEMO MODE with NONE of these set: the
# seeded gallery + the stubbed self-test build timeline work
# with zero keys. Fill these only to wire the real Codex +
# Supabase engine behind the seams marked `// STUB:`.
#
# Local use: copy this file to `.env.local` (Next.js convention,
# gitignored) and fill in values there. NEVER put real keys here.
# ============================================================

# --- Demo toggle -------------------------------------------
# Two flags resolve demo vs real mode (see src/lib/demo.ts):
#
#   CHALKBOX_DEMO_MODE    — server-side only (not shipped to the browser).
#   NEXT_PUBLIC_DEMO_MODE — exposed to the client bundle, so client
#                           components (e.g. CreateFlow) also know the mode.
#
# Resolution: EITHER flag = "true" forces demo mode. Otherwise the app is
# in demo mode UNLESS OPENAI_API_KEY is present AND neither flag = "true".
# Setting CHALKBOX_DEMO_MODE="false" opts into real mode even with no key.
# Tests always force demo mode via vitest.config.ts (spend guard).
CHALKBOX_DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# --- OpenAI / Codex ----------------------------------------
# GPT-5.6 Sol (generation) + Luna (safety/triage) via the Codex SDK.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Supabase (share links + gallery persistence) ----------
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
