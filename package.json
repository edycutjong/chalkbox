{
  "name": "chalkbox",
  "version": "1.3.0",
  "private": true,
  "description": "Chalkbox — a teacher types a misconception; Codex conjures a self-tested interactive math/physics manipulative behind a phone-friendly share link.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vite-node scripts/bench.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lighthouse": "npx --yes @lhci/cli autorun",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "next": "^15.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.4",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.8",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    }
  }
}
